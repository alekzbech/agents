{
  "servers": {
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-jira"],
      "env": {
        "ATLASSIAN_SITE_NAME": "headstart",
        "ATLASSIAN_USER_EMAIL": "${env:JIRA_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${env:JIRA_API_TOKEN}"
      }
    }
  }
}
