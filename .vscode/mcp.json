{
  "inputs": [
    {
      "id": "atlassian-token-v3",
      "type": "promptString",
      "description": "Atlassian API Token",
      "password": true
    }
  ],
  "servers": {
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-jira"],
      "env": {
        "ATLASSIAN_SITE_NAME": "headstart",
        "ATLASSIAN_USER_EMAIL": "aleksandra.bech@tsh.io",
        "ATLASSIAN_API_TOKEN": "${input:atlassian-token-v3}"
      }
    }
  }
}